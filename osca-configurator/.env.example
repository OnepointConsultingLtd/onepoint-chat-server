# Point at the OSCA Node server (REST). Default if unset: http://localhost:5000
VITE_OSCA_API_URL=http://localhost:5000

# Must match the server’s ADMIN_SECRET (see repo root .env). Without this, the UI uses demo data only.
VITE_OSCA_ADMIN_SECRET=

# Embed snippet defaults in Widget builder (Token & embed). Placeholders if unset.
# VITE_EMBED_SNIPPET_HTTP_URL=https://api.yourcompany.com
# VITE_EMBED_SNIPPET_WS_URL=wss://ws.yourcompany.com
# VITE_EMBED_SNIPPET_WIDGET_SCRIPT_URL=https://chat.yourcompany.com/widget.iife.js
