# Clerk (required)
VITE_CLERK_PUBLISHABLE_KEY=

# Osca backends — optional if you use defaults (localhost :5000 HTTP + WebSocket at /ws) or query params.
# Example local (WS URL may be host only; /ws is appended if missing):
# VITE_OSCA_HTTP_URL=http://localhost:5000
# VITE_OSCA_WS_URL=ws://localhost:5000
# Tenant token from osca-registry.clients (same as ONE_TIME_TOKEN / migration); optional if constants.ts matches registry.
# VITE_OSCA_CLIENT_TOKEN=osca_live_...
# Pin LightRAG project in the UI (skips registry lookup). Leave empty to use /api/tenant/context for the token’s project.
# VITE_OSCA_PROJECT_NAME=onepoint_v2

VITE_OSCA_HTTP_URL=
VITE_OSCA_WS_URL=
VITE_OSCA_CLIENT_TOKEN=
VITE_OSCA_PROJECT_NAME=
